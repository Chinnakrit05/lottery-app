{
  "name": "lottery-app",
  "version": "1.2.0",
  "description": "Love Number — ระบบจัดการหวย Desktop (Electron + Next.js + SQLite)",
  "author": "chinnakrit.mek@gmail.com",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n NEXT,ELECTRON -c blue,green \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:next": "next dev -p 3033",
    "dev:electron": "wait-on http://localhost:3033 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:next && npm run build:electron",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder -mwl",
    "publish:win": "npm run build && electron-builder --win --publish always",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "better-sqlite3": "^11.3.0",
    "electron-serve": "^1.3.0",
    "electron-updater": "^6.3.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "lucide-react": "^0.454.0",
    "next": "14.2.16",
    "next-themes": "^0.3.0",
    "recharts": "^2.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.16",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  }
}
